generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  FREE
  PRO
  SCALE
  AGENCY
  ADMIN
  ADVERTISER
  CREATOR
}

enum Platform {
  TIKTOK
  FACEBOOK
  INSTAGRAM
  YOUTUBE
}

enum AdType {
  VIDEO
  IMAGE
  CAROUSEL
}

enum HookType {
  CURIOSITY_GAP
  PAIN_POINT
  SOCIAL_PROOF
  PATTERN_INTERRUPT
  BOLD_CLAIM
  QUESTION
  STORY
  TUTORIAL
  OFFER
  FEAR
}

enum CtaType {
  SHOP_NOW
  LEARN_MORE
  SIGN_UP
  GET_OFFER
  WATCH_MORE
  BOOK_NOW
  DOWNLOAD
  CONTACT_US
  TRY_FREE
  OTHER
}

enum FunnelType {
  DIRECT_RESPONSE
  LEAD_GEN
  CONTENT_FIRST
  BRAND_AWARENESS
  RETARGETING
  PRODUCT_LAUNCH
}

enum RemixType {
  HOOKS
  SCRIPT
  ADCOPY
  BRIEF
  WIREFRAME
  STORYBOARD
  UGC
}

enum AlertFrequency {
  INSTANT
  DAILY_DIGEST
  WEEKLY_DIGEST
}

enum AdStatus {
  RAW
  ENRICHED
  CLASSIFIED
}

enum LifecycleStage {
  HIDDEN_GEM
  EARLY_SCALING
  GROWTH
  SATURATED
  DYING
}

enum TrendDirection {
  RISING
  STABLE
  DECLINING
}

enum PatternStatus {
  EMERGING
  TRENDING
  PEAKED
  FADING
}

enum AlertRuleType {
  VELOCITY_ALERT
  PATTERN_ALERT
}

enum BriefType {
  CREATIVE_BRIEF
  UGC_SCRIPT
  STORYBOARD
  CUSTOM
}

enum BriefStatus {
  SENT
  VIEWED
  ACCEPTED
  DECLINED
  COMPLETED
}

enum SimilarityType {
  HOOK_TEXT
  SCRIPT_STRUCTURE
  PRODUCT_MATCH
  LANDING_PAGE
}

// ─── Auth (NextAuth adapter) ──────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id                   String    @id @default(cuid())
  email                String?   @unique
  emailVerified        DateTime?
  name                 String?
  image                String?
  role                 UserRole  @default(FREE)
  userRole             UserRole  @default(ADVERTISER)
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique

  accounts   Account[]
  sessions   Session[]
  remixes    Remix[]
  savedAds   SavedAd[]
  folders    Folder[]
  alertRules    AlertRule[]
  notifications Notification[]
  usageLogs     UsageLog[]
  creatorReviews CreatorReview[]
  sentBriefs     SentBrief[]
  subscription   Subscription?
  sentBriefsNew  Brief[]         @relation("SentBriefs")
  reviewsGiven   CreatorReview2[] @relation("ReviewsGiven")
  creatorProfile CreatorProfile?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
  @@index([stripeCustomerId])
}

// ─── Subscriptions ────────────────────────────────────────────────────────────

model Subscription {
  id                String    @id @default(cuid())
  userId            String    @unique
  plan              UserRole  @default(FREE)
  creditsUsed       Int       @default(0)
  creditsLimit      Int       @default(10)
  billingCycleStart DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Ads ──────────────────────────────────────────────────────────────────────

model Ad {
  id              String    @id @default(cuid())
  platform        Platform
  externalId      String    @unique
  brandName       String
  productName     String?
  niche           String
  adType          AdType    @default(VIDEO)
  duration        Int?      // seconds; null for IMAGE/CAROUSEL
  country         String    @default("US")
  language        String    @default("en")

  // Creative
  hookText        String?   @db.Text
  hookType        HookType?
  ctaText         String?
  ctaType         CtaType?
  thumbnailUrl    String?
  videoUrl        String?
  landingPageUrl  String?

  // Spend intelligence
  estimatedSpendMin Float?
  estimatedSpendMax Float?

  // Lifecycle
  firstSeenAt     DateTime  @default(now())
  lastSeenAt      DateTime  @default(now())
  daysRunning     Int       @default(0)
  isActive        Boolean   @default(true)
  status          AdStatus  @default(RAW)

  // Velocity (cached from velocityEngine cron — updated every 6h)
  velocityScore      Float    @default(0)   // 0–100
  velocityTier       String   @default("STEADY") // EXPLOSIVE | HIGH | RISING | STEADY
  velocityUpdatedAt  DateTime?

  // Saturation (cached from saturationEngine cron — updated every 12h)
  saturationScore             Float?   // 0–100; null = not yet computed
  duplicateCount              Int      @default(0)
  duplicateAdvertiserCount    Int      @default(0)
  hookTextHash                String?  // pre-computed token hash for similarity lookup
  saturationUpdatedAt         DateTime?

  // Product Lifecycle
  productInsightId String?
  productInsight   ProductInsight? @relation(fields: [productInsightId], references: [id], onDelete: SetNull)

  anatomy       AdAnatomy?
  metrics       AdMetrics[]
  remixes       Remix[]
  savedBy       SavedAd[]
  notifications Notification[]
  duplicatesAsSource AdDuplicate[] @relation("DuplicateSource")
  duplicatesAsTarget AdDuplicate[] @relation("DuplicateTarget")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([platform])
  @@index([niche])
  @@index([isActive])
  @@index([firstSeenAt])
  @@index([lastSeenAt])
  @@index([daysRunning])
  @@index([velocityScore])
  @@index([velocityTier])
  @@index([platform, niche])
  @@index([platform, isActive])
  @@index([niche, isActive])
  @@index([niche, velocityScore])        // trending by niche
  @@index([isActive, velocityScore])     // live trending feed
  @@index([productInsightId])
  @@index([saturationScore])
  @@index([hookTextHash])
  @@index([niche, saturationScore])
}

// ─── Product Lifecycle Tracker ────────────────────────────────────────────────

model ProductInsight {
  id                    String         @id @default(cuid())
  productName           String
  productCategory       String         // normalised niche label
  lifecycleStage        LifecycleStage @default(HIDDEN_GEM)
  saturationScore       Float          @default(0)   // 0–100
  firstDetectedAt       DateTime
  peakDetectedAt        DateTime?      // when saturationScore was highest
  totalAdCount          Int            @default(0)
  uniqueAdvertiserCount Int            @default(0)
  avgDaysRunning        Float          @default(0)
  trendDirection        TrendDirection @default(RISING)
  priceRange            String?        // e.g. "$19–$39"
  topPlatform           String?        // platform with most ads for this product
  updatedAt             DateTime       @updatedAt

  ads Ad[]

  @@index([lifecycleStage])
  @@index([saturationScore])
  @@index([productCategory])
  @@index([trendDirection])
  @@index([updatedAt])
  @@index([lifecycleStage, saturationScore])
}

// ─── Ad Duplication Tracking ─────────────────────────────────────────────────

model AdDuplicate {
  id              String         @id @default(cuid())
  sourceAdId      String
  duplicateAdId   String
  similarityScore Float          // 0.0–1.0
  similarityType  SimilarityType
  detectedAt      DateTime       @default(now())

  sourceAd    Ad @relation("DuplicateSource",  fields: [sourceAdId],    references: [id], onDelete: Cascade)
  duplicateAd Ad @relation("DuplicateTarget",  fields: [duplicateAdId], references: [id], onDelete: Cascade)

  @@unique([sourceAdId, duplicateAdId, similarityType])
  @@index([sourceAdId])
  @@index([duplicateAdId])
  @@index([similarityType])
  @@index([detectedAt])
  @@index([sourceAdId, similarityScore])
}

// ─── Creative Pattern Recognition ────────────────────────────────────────────

model CreativePattern {
  id                String        @id @default(cuid())
  patternName       String        // e.g. "POV + Problem + Unexpected Solution"
  hookType          String        // dominant hook type across ads
  scriptStructure   String        // normalised formula e.g. "hook→problem→demo→cta"
  adType            String        // VIDEO | IMAGE | CAROUSEL (most common)
  emotionalTriggers Json          // string[] — most common triggers across ads
  avgVelocity       Float         @default(0)
  medianEngagement  Float         @default(0)
  nicheSpread       Json          // string[] — niches where pattern appears
  totalAdsUsing     Int           @default(0)
  growthRate        Float         @default(0)   // week-over-week % change in totalAdsUsing
  viralityScore     Float         @default(0)   // composite score
  exampleAdIds      Json          // String[] — up to 5 representative ad IDs
  status            PatternStatus @default(EMERGING)
  firstDetectedAt   DateTime
  lastUpdatedAt     DateTime      @updatedAt

  alertRules AlertRule[]

  @@index([status])
  @@index([viralityScore])
  @@index([status, viralityScore])
  @@index([hookType])
  @@index([lastUpdatedAt])
}

// ─── Ad Metrics (time-series) ─────────────────────────────────────────────────

model AdMetrics {
  id                 String   @id @default(cuid())
  adId               String
  likes              BigInt   @default(0)
  comments           BigInt   @default(0)
  shares             BigInt   @default(0)
  views              BigInt   @default(0)
  earlyVelocityScore Float    @default(0)
  recordedAt         DateTime @default(now())

  ad Ad @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@index([adId])
  @@index([adId, recordedAt])
  @@index([earlyVelocityScore])
  @@index([recordedAt])
}

// ─── Ad Anatomy (AI-generated breakdown) ─────────────────────────────────────

model AdAnatomy {
  id               String     @id @default(cuid())
  adId             String     @unique
  hookScore        Float?     // 0–100
  emotionalTriggers Json?     // string[] e.g. ["fear", "aspiration", "urgency"]
  scriptStructure  Json?      // { hook, problem, demo, proof, cta } with timestamps
  colorPalette     Json?      // { dominant: string[], accent: string, mood: string }
  audioMood        String?
  pacingNotes      String?    @db.Text
  targetPsychology String?    @db.Text
  fullScript       String?    @db.Text
  funnelType       FunnelType?
  aiModel          String?    // e.g. "claude-opus-4-6"
  generatedAt      DateTime   @default(now())

  ad Ad @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@index([funnelType])
}

// ─── Remixes ──────────────────────────────────────────────────────────────────

model Remix {
  id          String    @id @default(cuid())
  userId      String
  adId        String
  remixType   RemixType
  input       Json?     // brand voice, product info, platform target
  output      Json?     // generated variations array
  model       String?   // model used for generation
  tokensUsed  Int       @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  ad   Ad   @relation(fields: [adId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([adId])
  @@index([userId, remixType])
  @@index([createdAt])
}

// ─── Saved Ads & Folders ─────────────────────────────────────────────────────

model Folder {
  id     String @id @default(cuid())
  userId String
  name   String

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedAds SavedAd[]

  createdAt DateTime @default(now())

  @@unique([userId, name])
  @@index([userId])
}

model SavedAd {
  id       String  @id @default(cuid())
  userId   String
  adId     String
  folderId String?

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  ad     Ad      @relation(fields: [adId], references: [id], onDelete: Cascade)
  folder Folder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@unique([userId, adId])
  @@index([userId])
  @@index([folderId])
}

// ─── Alert Rules ──────────────────────────────────────────────────────────────

model AlertRule {
  id                String          @id @default(cuid())
  userId            String
  name              String          // user-supplied label
  ruleType          AlertRuleType   @default(VELOCITY_ALERT)
  niches            String[]        @default([]) // empty = all niches
  platforms         String[]        @default([]) // empty = all platforms
  velocityThreshold Float           @default(90) // 0–100 score
  keywords          String?         // space-separated keywords matched against hookText/productName
  frequency         AlertFrequency  @default(INSTANT)
  isActive          Boolean         @default(true)
  lastCheckedAt     DateTime?       // updated by cron after each pass
  emailLastSentAt   DateTime?       // rate-limit guard for digest emails

  // Pattern alert fields
  patternId         String?
  pattern           CreativePattern? @relation(fields: [patternId], references: [id], onDelete: SetNull)

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([isActive])
  @@index([patternId])
  @@index([ruleType])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id          String   @id @default(cuid())
  userId      String
  alertRuleId String?
  adId        String
  title       String
  body        String?
  isRead      Boolean  @default(false)
  emailSentAt DateTime?

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  alertRule AlertRule? @relation(fields: [alertRuleId], references: [id], onDelete: SetNull)
  ad        Ad         @relation(fields: [adId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, isRead])
  @@index([adId])
  @@index([alertRuleId])
}

// ─── Usage Log ────────────────────────────────────────────────────────────────

model UsageLog {
  id       String  @id @default(cuid())
  userId   String
  action   String  // e.g. "remix.script", "anatomy.view", "ad.search", "export.meta"
  metadata Json?   // { adId, remixType, tokensUsed, platform, ... }

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([userId, action])
  @@index([createdAt])
}

// ─── Creator Marketplace ──────────────────────────────────────────────────────

model Creator {
  id              String   @id @default(cuid())
  name            String
  profileImageUrl String?
  bio             String?  @db.Text
  email           String   @unique

  platforms       String[] @default([]) // "TikTok" | "Instagram" | "YouTube Shorts"
  niches          String[] @default([]) // "Beauty" | "Fitness" | "Kitchen" | "Tech" | "Pets" ...
  contentStyles   String[] @default([]) // "UGC Review" | "Unboxing" | "Tutorial" | "Storytime" ...

  priceRange      String   // e.g. "$50–$150 per video"
  turnaroundDays  Int      @default(7)  // typical delivery days
  portfolioUrls   String[] @default([]) // links to example content

  rating          Float    @default(0)
  reviewCount     Int      @default(0)
  completedBriefs Int      @default(0)

  country         String   @default("US")
  language        String   @default("en")

  isVerified      Boolean  @default(false)
  isAvailable     Boolean  @default(true)

  reviews         CreatorReview[]
  sentBriefs      SentBrief[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isAvailable])
  @@index([isVerified])
  @@index([rating])
  @@index([turnaroundDays])
}

model CreatorReview {
  id        String  @id @default(cuid())
  creatorId String
  userId    String
  rating    Int     // 1–5
  comment   String? @db.Text

  creator Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([creatorId, userId]) // one review per creator per user
  @@index([creatorId])
  @@index([userId])
}

model SentBrief {
  id            String      @id @default(cuid())
  userId        String
  creatorId     String
  adId          String?

  briefType     BriefType
  briefContent  Json        // the generated brief/script/storyboard data
  customMessage String?     @db.Text
  status        BriefStatus @default(SENT)
  responseToken String      @unique @default(cuid()) // public token for creator response link

  sentAt        DateTime    @default(now())
  respondedAt   DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  creator Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([creatorId])
  @@index([status])
  @@index([responseToken])
}

// ─── Creator Portal Models ────────────────────────────────────────────────────

model CreatorProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  displayName     String
  bio             String?  @db.Text
  profileImageUrl String?
  platforms       String[]
  niches          String[]
  contentStyles   String[]
  priceMin        Int
  priceMax        Int
  turnaroundDays  Int      @default(5)
  portfolioUrls   String[]
  country         String?
  language        String?  @default("English")
  isVerified      Boolean  @default(false)
  isAvailable     Boolean  @default(true)
  rating          Float    @default(0)
  reviewCount     Int      @default(0)
  completedBriefs Int      @default(0)
  profileViews    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  briefs          Brief[]
  reviews         CreatorReview2[]
}

model Brief {
  id            String         @id @default(cuid())
  creatorId     String
  creator       CreatorProfile @relation(fields: [creatorId], references: [id])
  senderUserId  String
  sender        User           @relation("SentBriefs", fields: [senderUserId], references: [id])
  productName   String
  brandName     String
  briefType     BriefType
  briefContent  Json?
  customMessage String?        @db.Text
  status        BriefStatus    @default(SENT)
  senderEmail   String?
  sentAt        DateTime       @default(now())
  respondedAt   DateTime?
  completedAt   DateTime?
  reviews       CreatorReview2[]
}

model CreatorReview2 {
  id         String         @id @default(cuid())
  creatorId  String
  creator    CreatorProfile @relation(fields: [creatorId], references: [id])
  reviewerId String
  reviewer   User           @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  rating     Int
  comment    String?        @db.Text
  briefId    String?
  brief      Brief?         @relation(fields: [briefId], references: [id])
  createdAt  DateTime       @default(now())
}

// ─── User relation extensions (back-references) ───────────────────────────────
