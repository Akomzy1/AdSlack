{
  "framework": "nextjs",

  "functions": {
    "src/app/api/ads/[id]/anatomy/route.ts": {
      "memory": 1024,
      "maxDuration": 300
    },
    "src/app/api/ads/[id]/remix/route.ts": {
      "memory": 1024,
      "maxDuration": 300
    },
    "src/app/api/cron/velocity/route.ts": {
      "memory": 512,
      "maxDuration": 300
    },
    "src/app/api/cron/saturation/route.ts": {
      "memory": 512,
      "maxDuration": 300
    },
    "src/app/api/cron/ingest/route.ts": {
      "memory": 512,
      "maxDuration": 300
    },
    "src/app/api/cron/alerts/route.ts": {
      "memory": 256,
      "maxDuration": 60
    },
    "src/app/api/admin/recalculate-products/route.ts": {
      "memory": 512,
      "maxDuration": 300
    },
    "src/app/api/admin/recalculate-patterns/route.ts": {
      "memory": 512,
      "maxDuration": 300
    }
  },

  "crons": [
    {
      "path": "/api/cron/ingest",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/cron/velocity",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/alerts",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/admin/recalculate-products",
      "schedule": "0 */12 * * *"
    },
    {
      "path": "/api/admin/recalculate-patterns",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/saturation",
      "schedule": "0 */12 * * *"
    }
  ],

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",   "value": "nosniff" },
        { "key": "X-Frame-Options",           "value": "DENY" },
        { "key": "X-XSS-Protection",          "value": "1; mode=block" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",        "value": "camera=(), microphone=(), geolocation=()" },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ]
}
